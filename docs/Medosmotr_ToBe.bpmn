<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_Medosmotr" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_Medosmotr">
    <bpmn:participant id="Participant_Medosmotr" name="Организация прохождения проф. медосмотра (To-Be)" processRef="Process_Medosmotr" />
    <bpmn:textAnnotation id="TextAnnotation_0vl8q87">
      <bpmn:text>Фамилия, Имя, Отчество, Дата рождения, крайний срок</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1cu4xk4" associationDirection="None" sourceRef="Task_UploadList" targetRef="TextAnnotation_0vl8q87" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Medosmotr" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Medosmotr">
      <bpmn:lane id="Lane_HR" name="Кадровый работник предприятия">
        <bpmn:flowNodeRef>StartEvent_Request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepareList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UploadList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveConclusion</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Chair" name="Председатель врачебной комиссии">
        <bpmn:flowNodeRef>Task_OpenARM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ExamDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateConclusion</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Patient" name="Пациент">
        <bpmn:flowNodeRef>Task_DeliverConclusion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PassExam</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Robots" name="Роботы IT-Клиники">
        <bpmn:flowNodeRef>Task_ReadRMQ</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ControlDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RequestActive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_DeadlineExpired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CloseExpired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Expired</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Request" name="Организовать медосмотр сотрудников">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_PrepareList" name="Подготовить список сотрудников на медосмотр">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UploadList" name="Загрузить список сотрудников">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_0xyb2x6</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_RMQ">
        <bpmn:targetRef>DataStore_RMQ</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:dataStoreReference id="DataStore_RMQ" name="RabbitMQ" />
    <bpmn:dataStoreReference id="DataStore_MIS" name="МИС IT-Клиника (1С)" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Request" targetRef="Task_PrepareList" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_PrepareList" targetRef="Task_UploadList" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_ReadRMQ" targetRef="Task_CreateRequest" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_CreateRequest" targetRef="Task_ControlDeadline" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ControlDeadline" targetRef="Gateway_RequestActive" />
    <bpmn:sequenceFlow id="Flow_7_no" name="Нет" sourceRef="Gateway_RequestActive" targetRef="Event_DeadlineExpired" />
    <bpmn:sequenceFlow id="Flow_10_yes" name="Да" sourceRef="Gateway_ExamDone" targetRef="Task_CreateConclusion" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_CreateConclusion" targetRef="Task_DeliverConclusion" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Event_DeadlineExpired" targetRef="Task_CloseExpired" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_CloseExpired" targetRef="EndEvent_Expired" />
    <bpmn:sequenceFlow id="Flow_0xyb2x6" sourceRef="Task_UploadList" targetRef="Task_ReadRMQ" />
    <bpmn:task id="Task_ReadRMQ" name="Робот: Чтение объектов RMQ">
      <bpmn:incoming>Flow_0xyb2x6</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:property id="Property_0ofryo7" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_03lea6r">
        <bpmn:sourceRef>DataStoreReference_1vw85yu</bpmn:sourceRef>
        <bpmn:targetRef>Property_0ofryo7</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_CreateRequest" name="Создать документы «Заявка на медосмотр»">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_MIS">
        <bpmn:targetRef>DataStore_MIS</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_ControlDeadline" name="Контроль крайнего срока заявки">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RequestActive" name="Заявка актуальна?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_no</bpmn:outgoing>
      <bpmn:outgoing>Flow_15m73go</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_OpenARM" name="Открыть АРМ председателя мед.комиссии и просмотреть список пациентов">
      <bpmn:incoming>Flow_0hq8ok5</bpmn:incoming>
      <bpmn:outgoing>Flow_1rg1g4s</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_ARM">
        <bpmn:targetRef>DataStore_ARM</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:dataStoreReference id="DataStore_ARM" name="МИС IT-Клиника (1С)" />
    <bpmn:intermediateCatchEvent id="Event_DeadlineExpired" name="Срок заявки истек">
      <bpmn:incoming>Flow_7_no</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDefinition_Deadline" />
    </bpmn:intermediateCatchEvent>
    <bpmn:dataStoreReference id="DataStoreReference_1vw85yu" name="RabbitMQ" />
    <bpmn:task id="Task_CloseExpired" name="Робот: Закрытие просроченных заявок на медосмотр">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_15m73go" name="Да" sourceRef="Gateway_RequestActive" targetRef="Task_PassExam" />
    <bpmn:sequenceFlow id="Flow_0hq8ok5" sourceRef="Task_PassExam" targetRef="Task_OpenARM" />
    <bpmn:exclusiveGateway id="Gateway_ExamDone" name="Медосмотр завершен?">
      <bpmn:incoming>Flow_1rg1g4s</bpmn:incoming>
      <bpmn:outgoing>Flow_10_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_0fn1ese</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1rg1g4s" sourceRef="Task_OpenARM" targetRef="Gateway_ExamDone" />
    <bpmn:sequenceFlow id="Flow_0fn1ese" name="Нет" sourceRef="Gateway_ExamDone" targetRef="Task_PassExam" />
    <bpmn:task id="Task_CreateConclusion" name="Сформировать и распечатать заключение медицинской комиссии">
      <bpmn:incoming>Flow_10_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DeliverConclusion" name="Получить распечатанное медицинское заключение и отнести его кадровому работнику">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_0d4l5my</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0i18foa" sourceRef="Task_ReceiveConclusion" targetRef="EndEvent_Success" />
    <bpmn:endEvent id="EndEvent_Success" name="Заявка успешно отработана">
      <bpmn:incoming>Flow_0i18foa</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ReceiveConclusion" name="Получить от пациента распечатанное заключение">
      <bpmn:incoming>Flow_0d4l5my</bpmn:incoming>
      <bpmn:outgoing>Flow_0i18foa</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0d4l5my" sourceRef="Task_DeliverConclusion" targetRef="Task_ReceiveConclusion" />
    <bpmn:endEvent id="EndEvent_Expired" name="Заявка закрыта по сроку">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_PassExam" name="Пройти обследования у необходимых врачей">
      <bpmn:incoming>Flow_15m73go</bpmn:incoming>
      <bpmn:incoming>Flow_0fn1ese</bpmn:incoming>
      <bpmn:outgoing>Flow_0hq8ok5</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
